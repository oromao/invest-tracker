{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Signals Generated (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "alpha_signals_total",
          "legendFormat": "Total signals",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 100 }
          ]}
        }
      }
    },
    {
      "id": 2,
      "title": "LONG Signals",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "alpha_signals_long_total", "legendFormat": "LONG", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "green", "mode": "fixed" } }
      }
    },
    {
      "id": 3,
      "title": "SHORT Signals",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "alpha_signals_short_total", "legendFormat": "SHORT", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 4,
      "title": "Active Strategies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "alpha_strategies_active", "legendFormat": "Active", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } }
      }
    },
    {
      "id": 5,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Latest Backtest Sharpe by Strategy",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "alpha_backtest_sharpe",
          "legendFormat": "{{strategy}}",
          "refId": "A"
        }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "green", "value": 1.0 }
          ]}
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["alpha-factory"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Alpha Factory",
  "uid": "alpha-factory-v1",
  "version": 1
}
