      "id": 1,
      "title": "Research Cycles / Hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (asset, timeframe) (increase(alpha_research_cycles_total_v2[1h]))",
          "legendFormat": "{{asset}} {{timeframe}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 2,
      "title": "Candidates / Hour",
