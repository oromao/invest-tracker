{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Exposure",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alpha_risk_total_exposure",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "decimals": 2, "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.15 }, { "color": "red", "value": 0.20 }] } } }
    },
    {
      "id": 2,
      "title": "Daily Loss",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alpha_risk_daily_loss",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "decimals": 2, "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.10 }] } } }
    },
    {
      "id": 3,
      "title": "Kill Switch",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alpha_risk_kill_switch",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 4,
      "title": "Risk by Asset",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alpha_risk_asset_exposure",
          "legendFormat": "{{asset}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 8 } } }
    },
    {
      "id": 5,
      "title": "Market Freshness",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alpha_data_freshness_seconds_v2{kind=\"market\"}",
          "legendFormat": "{{asset}} {{timeframe}}",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "alpha_data_freshness_seconds_v2{kind=\"signal\"}",
          "legendFormat": "signal {{asset}} {{timeframe}}",
          "refId": "B"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 6,
      "title": "Research Freshness",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alpha_data_freshness_seconds_v2{kind=\"research\"}",
          "legendFormat": "{{asset}} {{timeframe}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 7,
      "title": "Execution Errors / 1h",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(alpha_execution_errors_total_v2[1h])",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["alpha-factory", "risk", "freshness", "observability"],
  "templating": { "list": [] },
  "timezone": "America/Sao_Paulo",
  "time": { "from": "now-24h", "to": "now" },
  "title": "Alpha Factory - Risk & Freshness",
  "uid": "alpha-risk-freshness",
  "version": 1
}
