DATABASE_URL=postgresql+asyncpg://alpha:alpha@postgres:5432/alpha_factory
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
BINANCE_API_KEY=
BINANCE_API_SECRET=
ASSETS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT
TIMEFRAMES=1m,5m,15m,1h,4h,1d
TB_PT=0.02
TB_SL=0.01
TB_T=48
RISK_MAX_EXPOSURE=0.20
RISK_DAILY_LOSS_LIMIT=0.03
RISK_MIN_RR=1.5

# AI is optional and disabled by default.
# Supported providers: none, ollama, deepseek, gemini, openrouter, groq
AI_ENABLED=false
AI_PROVIDER=none
AI_TIMEOUT_SECONDS=15
AI_RETRIES=2
AI_MODEL=phi3:mini

# Ollama (local provider; no API key needed)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3:mini
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# URL do invest-tracker principal (opcional, para dados reais de portfolio)
INVEST_TRACKER_URL=

# Frontend Public API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
