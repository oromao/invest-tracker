# ─── Banco de dados (Neon PostgreSQL) ─────────────────────────────────────
# Criar em: https://neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/invest-tracker?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/invest-tracker?sslmode=require

# ─── Auth (NextAuth) ───────────────────────────────────────────────────────
# Gerar: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Cache e Rate Limiting (Upstash Redis) ────────────────────────────────
# Criar em: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Cron Jobs ────────────────────────────────────────────────────────────
# Gerar: openssl rand -hex 32
CRON_SECRET=

# ─── APIs de Cotações (opcionais) ─────────────────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# HG Brasil: https://hgbrasil.com/status/finance
HG_BRASIL_KEY=
